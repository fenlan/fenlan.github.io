  <entry>
    <title>hadoop之旅</title>
    <link href="http://fenlan.github.io/2017/09/22/hadoop/"/>
    <id>http://fenlan.github.io/2017/09/22/hadoop/</id>
    <published>2017-09-22T07:18:23.000Z</published>
